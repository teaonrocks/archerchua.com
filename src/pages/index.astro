---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { ChevronRight } from "@lucide/astro";

const projects = [
	{
		name: "One Day at a Time",
		href: "/blog/one-day-at-a-time",
		description:
			'A real-time, Kahoot-style web app for Youth Corps\' "One Day At A Time" poverty simulation experience, built with React, Next.js, Convex, and Tailwind.',
	},
	{
		name: "InvoiceThing",
		href: "/blog/invoicething",
		description:
			"A full-featured invoice management system for freelancers and small businesses, with invoice templates, client management, payment tracking, and reporting.",
	},
	{
		name: "OCBC Smart Banking Kiosk",
		href: "/blog/ocbc-smart-banking-kiosk-vtm",
		description:
			"An AI-assisted virtual teller prototype with voice transcription, local LLM intent routing, guided banking workflows, and WebRTC live-agent escalation.",
	},
];
---

<BaseLayout>
	<section class="space-y-12">
		<div class="space-y-4">
			<h1
				aria-label="Archer Chua"
				class="font-heading max-w-2xl text-4xl font-bold tracking-tight text-neutral-950 sm:text-7xl dark:text-white"
				data-scramble-name
			>
				Archer Chua
			</h1>
			<p
				class="font-body max-w-xl text-lg leading-8 text-neutral-600 dark:text-neutral-300"
			>
				I'm an aspiring software engineer passionate about technology and
				building software that solves real world problems. When I'm not
				commanding my army of AI agents, I'm probably nerding out about audio
				gear or enjoying a game of mahjong.
			</p>
		</div>

		<div
			class="space-y-4 border-t border-neutral-200 pt-10 dark:border-neutral-800"
			data-timeline-section
		>
			<div class="flex max-w-2xl items-center justify-between gap-4">
				<h2
					class="font-heading text-2xl sm:text-3xl font-bold tracking-tight text-neutral-950 dark:text-white"
					data-timeline-heading
				>
					Currently
				</h2>
				<button
					type="button"
					class="cursor-pointer rounded-full px-3 py-1 text-sm font-medium text-neutral-600 transition hover:text-neutral-950 focus:outline-none focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:text-neutral-300 dark:hover:text-white dark:focus-visible:ring-neutral-600 dark:focus-visible:ring-offset-neutral-950"
					aria-controls="timeline-list"
					aria-expanded="false"
					hidden
					data-timeline-toggle
				>
					View all
				</button>
			</div>
			<ul
				id="timeline-list"
				class="relative max-w-2xl space-y-5 before:absolute before:bottom-2 before:left-0 before:top-2 before:w-px before:-translate-x-1/2 before:bg-neutral-200 dark:before:bg-neutral-800"
			>
				<li class="relative pl-5">
					<span
						class="absolute left-0 top-2 size-2 -translate-x-1/2 rounded-full bg-neutral-400 dark:bg-neutral-500"
					></span>
					<div
						class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-4"
					>
						<div>
							<h3
								class="font-heading text-xl font-semibold text-neutral-950 dark:text-white"
							>
								Mobile Applications Engineer Intern
							</h3>
							<p class="text-neutral-600 dark:text-neutral-300">OCBC Bank</p>
							<p
								class="mt-2 max-w-xl text-sm leading-6 text-neutral-500 dark:text-neutral-400"
							>
								Supporting mobile banking engineering while learning production
								app workflows in an enterprise financial services environment.
							</p>
						</div>
						<p
							class="shrink-0 text-sm font-medium text-neutral-500 dark:text-neutral-400"
						>
							Mar 2026 - Mar 2027
						</p>
					</div>
				</li>
				<li class="relative pl-5">
					<span
						class="absolute left-0 top-2 size-2 -translate-x-1/2 rounded-full bg-neutral-400 dark:bg-neutral-500"
					></span>
					<div
						class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-4"
					>
						<div>
							<h3
								class="font-heading text-xl font-semibold text-neutral-950 dark:text-white"
							>
								Diploma in Digital Design and Development
							</h3>
							<p class="text-neutral-600 dark:text-neutral-300">
								Republic Polytechnic
							</p>
							<p
								class="mt-2 max-w-xl text-sm leading-6 text-neutral-500 dark:text-neutral-400"
							>
								Studying design thinking and technical development across user
								experience, games, and visual communication.
							</p>
						</div>
						<p
							class="shrink-0 text-sm font-medium text-neutral-500 dark:text-neutral-400"
						>
							Apr 2024 - Apr 2027
						</p>
					</div>
				</li>
				<li
					class="relative pl-5 transition duration-300 ease-out"
					hidden
					data-expanded-only
				>
					<span
						class="absolute left-0 top-2 size-2 -translate-x-1/2 rounded-full bg-neutral-400 dark:bg-neutral-500"
					></span>
					<div
						class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-4"
					>
						<div>
							<h3
								class="font-heading text-xl font-semibold text-neutral-950 dark:text-white"
							>
								Digital Content Developer Intern
							</h3>
							<p class="text-neutral-600 dark:text-neutral-300">Singrow</p>
							<p
								class="mt-2 max-w-xl text-sm leading-6 text-neutral-500 dark:text-neutral-400"
							>
								Developed and maintained the company website and internal tools
								to improve digital presence and operational efficiency.
							</p>
						</div>
						<p
							class="shrink-0 text-sm font-medium text-neutral-500 dark:text-neutral-400"
						>
							Apr 2023 - Aug 2023
						</p>
					</div>
				</li>
				<li
					class="relative pl-5 transition duration-300 ease-out"
					hidden
					data-expanded-only
				>
					<span
						class="absolute left-0 top-2 size-2 -translate-x-1/2 rounded-full bg-neutral-400 dark:bg-neutral-500"
					></span>
					<div
						class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-4"
					>
						<div>
							<h3
								class="font-heading text-xl font-semibold text-neutral-950 dark:text-white"
							>
								Higher Nitec in IT Applications Development
							</h3>
							<p class="text-neutral-600 dark:text-neutral-300">
								Institute of Technical Education
							</p>
							<p
								class="mt-2 max-w-xl text-sm leading-6 text-neutral-500 dark:text-neutral-400"
							>
								Focused on designing, developing, and supporting e-business and
								smart device applications.
							</p>
						</div>
						<p
							class="shrink-0 text-sm font-medium text-neutral-500 dark:text-neutral-400"
						>
							Apr 2022 - May 2024
						</p>
					</div>
				</li>
				<li
					class="relative pl-5 transition duration-300 ease-out"
					hidden
					data-expanded-only
				>
					<span
						class="absolute left-0 top-2 size-2 -translate-x-1/2 rounded-full bg-neutral-400 dark:bg-neutral-500"
					></span>
					<div
						class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-4"
					>
						<div>
							<h3
								class="font-heading text-xl font-semibold text-neutral-950 dark:text-white"
							>
								Desktop Support Engineer Intern
							</h3>
							<p class="text-neutral-600 dark:text-neutral-300">NCS Group</p>
							<p
								class="mt-2 max-w-xl text-sm leading-6 text-neutral-500 dark:text-neutral-400"
							>
								Provided IT support and device maintenance for corporate client
								environments.
							</p>
						</div>
						<p
							class="shrink-0 text-sm font-medium text-neutral-500 dark:text-neutral-400"
						>
							Jan 2021 - Jul 2021
						</p>
					</div>
				</li>
				<li
					class="relative pl-5 transition duration-300 ease-out"
					hidden
					data-expanded-only
				>
					<span
						class="absolute left-0 top-2 size-2 -translate-x-1/2 rounded-full bg-neutral-400 dark:bg-neutral-500"
					></span>
					<div
						class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-4"
					>
						<div>
							<h3
								class="font-heading text-xl font-semibold text-neutral-950 dark:text-white"
							>
								Nitec in Infocomm Technology
							</h3>
							<p class="text-neutral-600 dark:text-neutral-300">
								Institute of Technical Education
							</p>
							<p
								class="mt-2 max-w-xl text-sm leading-6 text-neutral-500 dark:text-neutral-400"
							>
								Focused on deploying, maintaining, and troubleshooting computing
								devices, networks, servers, and applications.
							</p>
						</div>
						<p
							class="shrink-0 text-sm font-medium text-neutral-500 dark:text-neutral-400"
						>
							Jan 2020 - Feb 2022
						</p>
					</div>
				</li>
			</ul>
		</div>

		<div
			class="space-y-4 border-t border-neutral-200 pt-10 dark:border-neutral-800"
		>
			<div class="flex max-w-2xl items-center justify-between gap-4">
				<h2
					class="font-heading text-2xl sm:text-3xl font-bold tracking-tight text-neutral-950 dark:text-white"
				>
					Projects
				</h2>
			</div>
			<ul class="max-w-2xl space-y-5">
				{
					projects.map((project) => (
						<li>
							<a
								class="group block transition hover:translate-x-1"
								href={project.href}
							>
								<h3 class="font-heading text-xl font-semibold text-neutral-950 transition group-hover:text-neutral-600 dark:text-white dark:group-hover:text-neutral-300">
									{project.name}
									<ChevronRight
										aria-hidden="true"
										class="ml-1 inline-block size-5 align-[-0.175em] text-neutral-400 transition group-hover:translate-x-1 group-hover:text-neutral-600 dark:text-neutral-500 dark:group-hover:text-neutral-300"
									/>
								</h3>
								<p class="mt-2 leading-7 text-neutral-600 transition group-hover:text-neutral-800 dark:text-neutral-300 dark:group-hover:text-neutral-200">
									{project.description}
								</p>
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</section>

	<script is:inline>
		const nameHeading = document.querySelector("[data-scramble-name]");
		const timelineSection = document.querySelector("[data-timeline-section]");
		const timelineHeading = timelineSection?.querySelector(
			"[data-timeline-heading]",
		);
		const timelineToggle = timelineSection?.querySelector(
			"[data-timeline-toggle]",
		);
		const timelineList = timelineSection?.querySelector("#timeline-list");
		const expandedItems =
			timelineSection?.querySelectorAll("[data-expanded-only]") ?? [];
		const prefersReducedMotion = window.matchMedia(
			"(prefers-reduced-motion: reduce)",
		).matches;
		const characters = "AEFHJKMNRSTVWXYacefhmnrstvwxy137?!/\\|";
		const frameDuration = 24;
		const revealSpeed = 0.56;
		const timelineDuration = 300;
		let timelineHeightTimeout;
		const scrambleRuns = new WeakMap();

		const getCollapsedTimelineHeight = () => {
			const visibleItems =
				timelineList?.querySelectorAll("li:not([data-expanded-only])") ?? [];
			const lastVisibleItem = visibleItems[visibleItems.length - 1];

			if (!lastVisibleItem) {
				return timelineList?.offsetHeight ?? 0;
			}

			return lastVisibleItem.offsetTop + lastVisibleItem.offsetHeight;
		};

		const scrambleText = (element, finalText) => {
			return new Promise((resolve) => {
				if (!element || !finalText) {
					resolve(false);
					return;
				}

				const run = (scrambleRuns.get(element) ?? 0) + 1;
				scrambleRuns.set(element, run);

				if (prefersReducedMotion) {
					element.textContent = finalText;
					resolve(true);
					return;
				}

				let frame = 0;

				const scramble = () => {
					if (scrambleRuns.get(element) !== run) {
						resolve(false);
						return;
					}

					const nextText = finalText
						.split("")
						.map((character, index) => {
							if (character === " " || index < frame * revealSpeed) {
								return character;
							}

							return characters[Math.floor(Math.random() * characters.length)];
						})
						.join("");

					element.textContent = nextText;

					if (frame * revealSpeed < finalText.length) {
						frame += 1;
						window.setTimeout(scramble, frameDuration);
					} else {
						element.textContent = finalText;
						resolve(true);
					}
				};

				scramble();
			});
		};

		const setExpanded = (isExpanded, shouldAnimateHeading = true) => {
			const shouldAnimateTimelineHeight =
				timelineList && !prefersReducedMotion && shouldAnimateHeading;
			const startHeight = timelineList?.offsetHeight ?? 0;

			if (timelineHeading) {
				const headingText = isExpanded ? "Work & Education" : "Currently";

				if (shouldAnimateHeading) {
					if (timelineToggle) {
						timelineToggle.disabled = true;
					}

					scrambleText(timelineHeading, headingText).finally(() => {
						if (timelineToggle) {
							timelineToggle.disabled = false;
						}
					});
				} else {
					timelineHeading.textContent = headingText;
				}
			}

			if (timelineToggle) {
				timelineToggle.setAttribute("aria-expanded", String(isExpanded));
				timelineToggle.textContent = isExpanded ? "Show less" : "View all";
			}

			if (shouldAnimateTimelineHeight) {
				clearTimeout(timelineHeightTimeout);
				timelineList.style.height = `${startHeight}px`;
				timelineList.style.clipPath = "inset(0 -0.75rem 0 -0.75rem)";
				timelineList.style.transition = `height ${timelineDuration}ms ease`;
			}

			let endHeight = startHeight;

			if (shouldAnimateTimelineHeight && !isExpanded) {
				endHeight = getCollapsedTimelineHeight();
			}

			expandedItems.forEach((item) => {
				if (isExpanded) {
					item.removeAttribute("hidden");
					item.classList.add("opacity-0", "-translate-y-1");
					item.classList.remove("opacity-100", "translate-y-0");

					window.requestAnimationFrame(() => {
						item.classList.remove("opacity-0", "-translate-y-1");
						item.classList.add("opacity-100", "translate-y-0");
					});
					return;
				}

				item.classList.add("opacity-0", "-translate-y-1");
				item.classList.remove("opacity-100", "translate-y-0");

				if (prefersReducedMotion) {
					item.setAttribute("hidden", "");
					return;
				}

				window.setTimeout(() => {
					item.setAttribute("hidden", "");
				}, timelineDuration);
			});

			if (shouldAnimateTimelineHeight) {
				if (isExpanded) {
					endHeight = timelineList.scrollHeight;
				}

				window.requestAnimationFrame(() => {
					timelineList.style.height = `${endHeight}px`;
				});

				timelineHeightTimeout = window.setTimeout(() => {
					timelineList.style.removeProperty("height");
					timelineList.style.removeProperty("clip-path");
					timelineList.style.removeProperty("transition");
				}, timelineDuration);
			}
		};

		scrambleText(nameHeading, nameHeading?.textContent?.trim() ?? "");

		if (timelineToggle && expandedItems.length > 0) {
			timelineToggle.hidden = false;
			setExpanded(false, false);
			timelineToggle.addEventListener("click", () => {
				const isExpanded =
					timelineToggle.getAttribute("aria-expanded") === "true";

				setExpanded(!isExpanded);
			});
		}
	</script>
</BaseLayout>
