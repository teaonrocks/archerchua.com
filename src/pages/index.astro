---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { CircleCheck, CircleX, Download } from "@lucide/astro";

const projects = [
	{
		name: "One Day at a Time",
		href: "/blog/one-day-at-a-time",
		description:
			'A real-time lobby app for Youth Corps\' "One Day At A Time" poverty simulation, built to keep large groups in sync while replacing Excel-driven choices with mobile-friendly flows.',
	},
	{
		name: "InvoiceThing",
		href: "/blog/invoicething",
		description:
			"A lightweight React invoice tool I built for my live sound freelance work, shaped by weekly use and expanded after others saw it could solve their invoicing pain too.",
	},
	{
		name: "OCBC Smart Banking Kiosk",
		href: "/blog/ocbc-smart-banking-kiosk-vtm",
		description:
			"A local-AI virtual teller prototype where voice requests become guided banking flows, with WebRTC video, screen sharing, and annotations ready when a human agent needs to step in.",
	},
];

const title = "Archer Chua | Software Engineer";
const description =
	"Portfolio of Archer Chua, an aspiring software engineer focused on mobile applications, practical software projects, and thoughtful product experiences.";
const site = Astro.site ?? new URL("https://archerchua.com");
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Archer Chua",
	url: new URL("/", site).toString(),
	jobTitle: "Mobile Applications Engineer Intern",
	worksFor: {
		"@type": "Organization",
		name: "OCBC Bank",
	},
	sameAs: [
		"https://x.com/teaonrocks",
		"https://github.com/teaonrocks",
		"https://linkedin.com/in/archerchua",
	],
};
---

<BaseLayout title={title} description={description} canonicalPath="/" jsonLd={jsonLd}>
	<section class="space-y-14 sm:space-y-16">
		<div class="space-y-5">
			<h1
				aria-label="Archer Chua"
				class="type-display max-w-2xl whitespace-nowrap"
				data-scramble-name
			>
				Archer Chua
			</h1>
			<p class="type-lede">
				I'm an aspiring software engineer passionate about technology and
				building software that solves real world problems. When I'm not
				commanding my army of AI agents, I'm probably nerding out about audio
				gear or enjoying a game of mahjong.
			</p>
		</div>

		<div class="section-block space-y-5" data-timeline-section>
			<div class="flex max-w-2xl items-center justify-between gap-4">
				<h2
					class="type-section"
					data-timeline-heading
				>
					Currently
				</h2>
				<button
					type="button"
					class="text-action cursor-pointer bg-transparent text-sm"
					aria-controls="timeline-content"
					aria-expanded="false"
					hidden
					data-timeline-toggle
				>
					View all
				</button>
			</div>
			<div class="max-w-2xl" id="timeline-content" data-timeline-content>
			<ul
				id="timeline-list"
				class="relative space-y-6 before:absolute before:bottom-2 before:left-0 before:top-2 before:w-px before:-translate-x-1/2 before:bg-neutral-200 dark:before:bg-neutral-800"
			>
				<li class="relative pl-5">
					<span
						class="absolute left-0 top-2 size-2 -translate-x-1/2 rounded-full bg-neutral-400 dark:bg-neutral-500"
						aria-hidden="true"
					></span>
					<div
						class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-4"
					>
						<div>
							<h3
								class="type-item-title"
							>
								Mobile Applications Engineer Intern
							</h3>
							<p class="text-neutral-600 dark:text-neutral-400">OCBC Bank</p>
							<p
								class="type-muted mt-2 max-w-xl"
							>
								Supporting mobile banking engineering while learning production
								app workflows in an enterprise financial services environment.
							</p>
						</div>
						<p
							class="shrink-0 text-sm font-medium leading-6 text-neutral-500 dark:text-neutral-500"
						>
							Mar 2026 - Mar 2027
						</p>
					</div>
				</li>
				<li class="relative pl-5">
					<span
						class="absolute left-0 top-2 size-2 -translate-x-1/2 rounded-full bg-neutral-400 dark:bg-neutral-500"
						aria-hidden="true"
					></span>
					<div
						class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-4"
					>
						<div>
							<h3
								class="type-item-title"
							>
								Diploma in Digital Design and Development
							</h3>
							<p class="text-neutral-600 dark:text-neutral-400">
								Republic Polytechnic
							</p>
							<p
								class="type-muted mt-2 max-w-xl"
							>
								Studying design thinking and technical development across user
								experience, games, and visual communication.
							</p>
						</div>
						<p
							class="shrink-0 text-sm font-medium leading-6 text-neutral-500 dark:text-neutral-500"
						>
							Apr 2024 - Apr 2027
						</p>
					</div>
				</li>
				<li
					class="relative pl-5 transition duration-300 ease-out"
					hidden
					data-expanded-only
				>
					<span
						class="absolute left-0 top-2 size-2 -translate-x-1/2 rounded-full bg-neutral-400 dark:bg-neutral-500"
						aria-hidden="true"
					></span>
					<div
						class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-4"
					>
						<div>
							<h3
								class="type-item-title"
							>
								Digital Content Developer Intern
							</h3>
							<p class="text-neutral-600 dark:text-neutral-400">Singrow</p>
							<p
								class="type-muted mt-2 max-w-xl"
							>
								Developed and maintained the company website and internal tools
								to improve digital presence and operational efficiency.
							</p>
						</div>
						<p
							class="shrink-0 text-sm font-medium leading-6 text-neutral-500 dark:text-neutral-500"
						>
							Apr 2023 - Aug 2023
						</p>
					</div>
				</li>
				<li
					class="relative pl-5 transition duration-300 ease-out"
					hidden
					data-expanded-only
				>
					<span
						class="absolute left-0 top-2 size-2 -translate-x-1/2 rounded-full bg-neutral-400 dark:bg-neutral-500"
						aria-hidden="true"
					></span>
					<div
						class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-4"
					>
						<div>
							<h3
								class="type-item-title"
							>
								Higher Nitec in IT Applications Development
							</h3>
							<p class="text-neutral-600 dark:text-neutral-400">
								Institute of Technical Education
							</p>
							<p
								class="type-muted mt-2 max-w-xl"
							>
								Focused on designing, developing, and supporting e-business and
								smart device applications.
							</p>
						</div>
						<p
							class="shrink-0 text-sm font-medium leading-6 text-neutral-500 dark:text-neutral-500"
						>
							Apr 2022 - May 2024
						</p>
					</div>
				</li>
				<li
					class="relative pl-5 transition duration-300 ease-out"
					hidden
					data-expanded-only
				>
					<span
						class="absolute left-0 top-2 size-2 -translate-x-1/2 rounded-full bg-neutral-400 dark:bg-neutral-500"
						aria-hidden="true"
					></span>
					<div
						class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-4"
					>
						<div>
							<h3
								class="type-item-title"
							>
								Desktop Support Engineer Intern
							</h3>
							<p class="text-neutral-600 dark:text-neutral-400">NCS Group</p>
							<p
								class="type-muted mt-2 max-w-xl"
							>
								Provided IT support and device maintenance for corporate client
								environments.
							</p>
						</div>
						<p
							class="shrink-0 text-sm font-medium leading-6 text-neutral-500 dark:text-neutral-500"
						>
							Jan 2021 - Jul 2021
						</p>
					</div>
				</li>
				<li
					class="relative pl-5 transition duration-300 ease-out"
					hidden
					data-expanded-only
				>
					<span
						class="absolute left-0 top-2 size-2 -translate-x-1/2 rounded-full bg-neutral-400 dark:bg-neutral-500"
						aria-hidden="true"
					></span>
					<div
						class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between sm:gap-4"
					>
						<div>
							<h3
								class="type-item-title"
							>
								Nitec in Infocomm Technology
							</h3>
							<p class="text-neutral-600 dark:text-neutral-400">
								Institute of Technical Education
							</p>
							<p
								class="type-muted mt-2 max-w-xl"
							>
								Focused on deploying, maintaining, and troubleshooting computing
								devices, networks, servers, and applications.
							</p>
						</div>
						<p
							class="shrink-0 text-sm font-medium leading-6 text-neutral-500 dark:text-neutral-500"
						>
							Jan 2020 - Feb 2022
						</p>
					</div>
				</li>
			</ul>
			<div
				class="type-muted pt-5 pl-5 transition duration-300 ease-out"
				hidden
				data-expanded-only
			>
				<a
					class="underline decoration-neutral-300 underline-offset-4 transition hover:text-neutral-700 hover:decoration-neutral-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-neutral-950 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50 dark:decoration-neutral-700 dark:hover:text-neutral-300 dark:hover:decoration-neutral-500 dark:focus-visible:ring-neutral-300 dark:focus-visible:ring-offset-neutral-900"
					href="https://linkedin.com/in/archerchua"
					target="_blank"
					rel="noreferrer"
					aria-label="View Archer Chua's work and education on LinkedIn, opens in a new tab"
				>
					More on LinkedIn
				</a>
			</div>
			</div>
		</div>

		<div class="section-block space-y-5">
			<div class="flex max-w-2xl items-center justify-between gap-4">
				<h2
					class="type-section"
				>
					Projects
				</h2>
			</div>
			<ul class="max-w-2xl divide-y divide-neutral-200 dark:divide-neutral-800">
				{
					projects.map((project) => (
						<li>
							<a
								class="group block py-5 transition focus:outline-none focus-visible:ring-2 focus-visible:ring-neutral-950 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-50 dark:focus-visible:ring-neutral-300 dark:focus-visible:ring-offset-neutral-900"
								href={project.href}
							>
								<h3 class="type-item-title underline decoration-transparent underline-offset-8 transition group-hover:text-neutral-700 group-hover:decoration-neutral-400 dark:group-hover:text-neutral-300 dark:group-hover:decoration-neutral-600">
									{project.name}
								</h3>
								<p class="type-copy mt-2 transition group-hover:text-neutral-800 dark:group-hover:text-neutral-300">
									{project.description}
								</p>
							</a>
						</li>
					))
				}
			</ul>
		</div>

		<div class="section-block space-y-4">
			<h2
				class="type-section"
			>
				Links
			</h2>
			<ul
				class="link-list"
			>
				<li>
					<a
						class="text-action"
						href="https://x.com/teaonrocks"
						target="_blank"
						rel="noreferrer"
						aria-label="Archer Chua on X, opens in a new tab"
					>
						<span aria-hidden="true">X</span>
						<span class="sr-only">Archer Chua on X</span>
					</a>
				</li>
				<li>
					<a
						class="text-action"
						href="https://github.com/teaonrocks"
						target="_blank"
						rel="noreferrer"
						aria-label="Archer Chua on GitHub, opens in a new tab"
					>
						GitHub
					</a>
				</li>
				<li>
					<a
						class="text-action"
						href="https://linkedin.com/in/archerchua"
						target="_blank"
						rel="noreferrer"
						aria-label="Archer Chua on LinkedIn, opens in a new tab"
					>
						LinkedIn
					</a>
				</li>
				<li>
					<button
						type="button"
						class="text-action cursor-pointer bg-transparent"
						data-copy-email="arxherchua@gmail.com"
						aria-label="Copy Archer Chua's email address"
					>
						Email
					</button>
				</li>
				<li>
					<a
						class="text-action"
						href="/resume.pdf"
						download="Archer-Chua-Resume.pdf"
						data-resume-download
						aria-label="Download Archer Chua's resume PDF"
					>
						Resume
					</a>
				</li>
			</ul>
		</div>
	</section>

	<div
		class="pointer-events-none fixed bottom-[calc(1.25rem+env(safe-area-inset-bottom))] left-1/2 z-50 w-[min(calc(100%-2rem),22.25rem)] rounded-xl border border-neutral-200 bg-white px-4 py-3.5 text-sm font-medium text-neutral-950 shadow-[0_16px_40px_rgba(0,0,0,0.16)] dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-200 dark:shadow-black/40 sm:bottom-[calc(1.5rem+env(safe-area-inset-bottom))]"
		role="status"
		aria-live="polite"
		aria-hidden="true"
		data-toast-state="closed"
		data-toast
	>
		<span class="flex items-center gap-3">
			<span
				class="flex size-4 shrink-0 items-center justify-center text-neutral-950 dark:text-neutral-200"
				aria-hidden="true"
			>
				<span data-toast-icon="success">
					<CircleCheck class="size-4" stroke-width="2.25" />
				</span>
				<span data-toast-icon="error" hidden>
					<CircleX class="size-4" stroke-width="2.25" />
				</span>
				<span data-toast-icon="info" hidden>
					<Download class="size-4" stroke-width="2.25" />
				</span>
			</span>
			<span class="min-w-0 flex-1 leading-5 tracking-[-0.01em]" data-toast-message
			></span>
		</span>
	</div>

	<style>
		[data-toast] {
			opacity: 0;
			visibility: hidden;
			transform: translate3d(-50%, 0.5rem, 0) scale(0.985);
			transition:
				opacity 160ms ease,
				transform 220ms cubic-bezier(0.16, 1, 0.3, 1),
				visibility 0s linear 220ms;
			will-change: opacity, transform;
		}

		[data-toast][data-toast-state="open"] {
			opacity: 1;
			visibility: visible;
			transform: translate3d(-50%, 0, 0) scale(1);
			transition:
				opacity 140ms ease,
				transform 220ms cubic-bezier(0.16, 1, 0.3, 1),
				visibility 0s;
		}

		@media (prefers-reduced-motion: reduce) {
			[data-toast] {
				transition: none;
				transform: translate3d(-50%, 0, 0);
			}
		}
	</style>

	<script is:inline>
		const nameHeading = document.querySelector("[data-scramble-name]");
		const timelineSection = document.querySelector("[data-timeline-section]");
		const timelineHeading = timelineSection?.querySelector(
			"[data-timeline-heading]",
		);
		const timelineToggle = timelineSection?.querySelector(
			"[data-timeline-toggle]",
		);
		const timelineContent = timelineSection?.querySelector(
			"[data-timeline-content]",
		);
		const timelineList = timelineSection?.querySelector("#timeline-list");
		const expandedItems =
			timelineSection?.querySelectorAll("[data-expanded-only]") ?? [];
		const prefersReducedMotion = window.matchMedia(
			"(prefers-reduced-motion: reduce)",
		).matches;
		const characters = "AEFHJKMNRSTVWXYacefhmnrstvwxy137?!/\\|";
		const frameDuration = 24;
		const revealSpeed = 0.56;
		const timelineDuration = 300;
		let timelineHeightTimeout;
		let toastTimeout;
		const scrambleRuns = new WeakMap();

		const toast = document.querySelector("[data-toast]");
		const toastMessage = toast?.querySelector("[data-toast-message]");
		const toastIcons = toast?.querySelectorAll("[data-toast-icon]") ?? [];

		const showToast = (message, tone = "success") => {
			if (!toast || !toastMessage) {
				return;
			}

			window.clearTimeout(toastTimeout);
			toastMessage.textContent = message;
			toastIcons.forEach((icon) => {
				icon.hidden = icon.getAttribute("data-toast-icon") !== tone;
			});
			toast.setAttribute("aria-hidden", "false");
			toast.setAttribute("data-toast-state", "open");

			toastTimeout = window.setTimeout(() => {
				toast.setAttribute("data-toast-state", "closed");
				toast.setAttribute("aria-hidden", "true");
			}, 2200);
		};

		const copyToClipboard = async (value) => {
			if (navigator.clipboard?.writeText) {
				await navigator.clipboard.writeText(value);
				return;
			}

			const textarea = document.createElement("textarea");
			textarea.value = value;
			textarea.setAttribute("readonly", "");
			textarea.style.position = "fixed";
			textarea.style.opacity = "0";
			document.body.append(textarea);
			textarea.select();
			document.execCommand("copy");
			textarea.remove();
		};

		const getCollapsedTimelineHeight = () => {
			const visibleItems =
				timelineList?.querySelectorAll("li:not([data-expanded-only])") ?? [];
			const lastVisibleItem = visibleItems[visibleItems.length - 1];

			if (!lastVisibleItem) {
				return timelineList?.offsetHeight ?? 0;
			}

			return lastVisibleItem.offsetTop + lastVisibleItem.offsetHeight;
		};

		const scrambleText = (element, finalText) => {
			return new Promise((resolve) => {
				if (!element || !finalText) {
					resolve(false);
					return;
				}

				const run = (scrambleRuns.get(element) ?? 0) + 1;
				scrambleRuns.set(element, run);

				if (prefersReducedMotion) {
					element.textContent = finalText;
					resolve(true);
					return;
				}

				let frame = 0;

				const scramble = () => {
					if (scrambleRuns.get(element) !== run) {
						resolve(false);
						return;
					}

					const nextText = finalText
						.split("")
						.map((character, index) => {
							if (character === " " || index < frame * revealSpeed) {
								return character;
							}

							return characters[Math.floor(Math.random() * characters.length)];
						})
						.join("");

					element.textContent = nextText;

					if (frame * revealSpeed < finalText.length) {
						frame += 1;
						window.setTimeout(scramble, frameDuration);
					} else {
						element.textContent = finalText;
						resolve(true);
					}
				};

				scramble();
			});
		};

		const setExpanded = (isExpanded, shouldAnimateHeading = true) => {
			const shouldAnimateTimelineHeight =
				timelineContent && !prefersReducedMotion && shouldAnimateHeading;
			const startHeight = timelineContent?.offsetHeight ?? 0;

			if (timelineHeading) {
				const headingText = isExpanded ? "Work & Education" : "Currently";

				if (shouldAnimateHeading) {
					if (timelineToggle) {
						timelineToggle.disabled = true;
					}

					scrambleText(timelineHeading, headingText).finally(() => {
						if (timelineToggle) {
							timelineToggle.disabled = false;
						}
					});
				} else {
					timelineHeading.textContent = headingText;
				}
			}

			if (timelineToggle) {
				timelineToggle.setAttribute("aria-expanded", String(isExpanded));
				timelineToggle.textContent = isExpanded ? "Show less" : "View all";
			}

			if (shouldAnimateTimelineHeight) {
				clearTimeout(timelineHeightTimeout);
				timelineContent.style.height = `${startHeight}px`;
				timelineContent.style.clipPath = "inset(0 -0.75rem 0 -0.75rem)";
				timelineContent.style.transition = `height ${timelineDuration}ms ease`;
			}

			let endHeight = startHeight;

			if (shouldAnimateTimelineHeight && !isExpanded) {
				endHeight = getCollapsedTimelineHeight();
			}

			expandedItems.forEach((item) => {
				if (isExpanded) {
					item.removeAttribute("hidden");
					item.classList.add("opacity-0", "-translate-y-1");
					item.classList.remove("opacity-100", "translate-y-0");

					window.requestAnimationFrame(() => {
						item.classList.remove("opacity-0", "-translate-y-1");
						item.classList.add("opacity-100", "translate-y-0");
					});
					return;
				}

				item.classList.add("opacity-0", "-translate-y-1");
				item.classList.remove("opacity-100", "translate-y-0");

				if (prefersReducedMotion) {
					item.setAttribute("hidden", "");
					return;
				}

				window.setTimeout(() => {
					item.setAttribute("hidden", "");
				}, timelineDuration);
			});

			if (shouldAnimateTimelineHeight) {
				if (isExpanded) {
					endHeight = timelineContent.scrollHeight;
				}

				window.requestAnimationFrame(() => {
					timelineContent.style.height = `${endHeight}px`;
				});

				timelineHeightTimeout = window.setTimeout(() => {
					timelineContent.style.removeProperty("height");
					timelineContent.style.removeProperty("clip-path");
					timelineContent.style.removeProperty("transition");
				}, timelineDuration);
			}
		};

		scrambleText(nameHeading, nameHeading?.textContent?.trim() ?? "");

		document.querySelectorAll("[data-copy-email]").forEach((button) => {
			button.addEventListener("click", async () => {
				const email = button.getAttribute("data-copy-email");

				if (!email) {
					return;
				}

				try {
					await copyToClipboard(email);
					showToast("Email copied to clipboard");
				} catch {
					showToast("Could not copy email", "error");
				}
			});
		});

		document.querySelectorAll("[data-resume-download]").forEach((link) => {
			link.addEventListener("click", () => {
				showToast("Downloading resume", "info");
			});
		});

		if (timelineToggle && expandedItems.length > 0) {
			timelineToggle.hidden = false;
			setExpanded(false, false);
			timelineToggle.addEventListener("click", () => {
				const isExpanded =
					timelineToggle.getAttribute("aria-expanded") === "true";

				setExpanded(!isExpanded);
			});
		}
	</script>
</BaseLayout>
